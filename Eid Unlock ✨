TYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eid ul Adha Surprise</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
overflow:hidden;
background:
linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.7)),
url('https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=1974&auto=format&fit=crop');
background-size:cover;
background-position:center;
color:white;
}

.container{
width:95%;
max-width:450px;
padding:30px;
border-radius:25px;
backdrop-filter:blur(15px);
background:rgba(255,255,255,0.08);
border:1px solid rgba(255,255,255,0.2);
box-shadow:0 8px 32px rgba(0,0,0,0.5);
text-align:center;
animation:fade 1s ease;
}

.page{
display:none;
}

.active{
display:block;
}

h1,h2,h3{
margin-bottom:15px;
}

p{
margin-bottom:20px;
color:#ddd;
}

#timer{
font-size:2rem;
font-weight:bold;
color:#00ffae;
margin:20px 0;
}

.btn{
padding:12px 25px;
border:none;
border-radius:40px;
background:linear-gradient(45deg,#00c853,#64dd17);
color:white;
font-size:1rem;
cursor:pointer;
transition:0.3s;
margin-top:15px;
}

.btn:hover{
transform:scale(1.05);
}

.btn:disabled{
background:gray;
cursor:not-allowed;
}

.options{
display:grid;
grid-template-columns:1fr 1fr;
gap:12px;
margin-top:20px;
}

.option-btn{
padding:12px;
border:none;
border-radius:15px;
background:rgba(255,255,255,0.1);
color:white;
cursor:pointer;
transition:0.3s;
border:1px solid rgba(255,255,255,0.2);
}

.option-btn:hover{
background:rgba(255,255,255,0.2);
transform:translateY(-3px);
}

.progress{
height:10px;
background:rgba(255,255,255,0.1);
border-radius:20px;
overflow:hidden;
margin-bottom:20px;
}

.progress-bar{
height:100%;
width:25%;
background:#00ffae;
transition:0.5s;
}

.fireworks{
font-size:3rem;
animation:pop 1s infinite alternate;
}

@keyframes fade{
from{
opacity:0;
transform:translateY(20px);
}
to{
opacity:1;
transform:translateY(0);
}
}

@keyframes pop{
from{
transform:scale(1);
}
to{
transform:scale(1.2);
}
}

</style>
</head>

<body>

<div class="container">

<div class="progress">
<div class="progress-bar" id="progressBar"></div>
</div>

<!-- PAGE 1 -->

<div id="page1" class="page active">
<h1>Eid ul Adha Surprise 🌙</h1>
<p>Special surprise unlock hone wala hai...</p>

<div id="timer">00:00:00</div>

<button id="next1" class="btn" disabled onclick="nextPage(2)">
Start Journey
</button>
</div>

<!-- PAGE 2 -->

<div id="page2" class="page">
<h3>Stage 1 😈</h3>

<p>
Wo konsa lafz hai jo likhne par galat hota hai magar bolne par sahi?
</p>

<div class="options">

<button class="option-btn" onclick="checkAnswer(this,false)">
Sahi
</button>

<button class="option-btn" onclick="checkAnswer(this,true)">
Galat
</button>

<button class="option-btn" onclick="checkAnswer(this,false)">
Jhoot
</button>

<button class="option-btn" onclick="checkAnswer(this,false)">
Sach
</button>

</div>

<button id="next2" class="btn" disabled onclick="nextPage(3)">
Next Stage
</button>

</div>

<!-- PAGE 3 -->

<div id="page3" class="page">

<h3>Stage 2 🧠</h3>

<p>
Wo kya cheez hai jo tootne ke baad aur zyada kaam aati hai?
</p>

<div class="options">

<button class="option-btn" onclick="checkAnswer(this,false)">
Mobile
</button>

<button class="option-btn" onclick="checkAnswer(this,false)">
Mirror
</button>

<button class="option-btn" onclick="checkAnswer(this,true)">
Record
</button>

<button class="option-btn" onclick="checkAnswer(this,false)">
Glass
</button>

</div>

<button id="next3" class="btn" disabled onclick="nextPage(4)">
Final Stage
</button>

</div>

<!-- PAGE 4 -->

<div id="page4" class="page">

<h3>Final Boss ☠️</h3>

<p>
Aisi konsi cheez hai jo jitni zyada saaf karo utni hi kaali hoti jati hai?
</p>

<div class="options">

<button class="option-btn" onclick="checkAnswer(this,false)">
Kapra
</button>

<button class="option-btn" onclick="checkAnswer(this,false)">
Pathar
</button>

<button class="option-btn" onclick="checkAnswer(this,true)">
Blackboard
</button>

<button class="option-btn" onclick="checkAnswer(this,false)">
Shoe
</button>

</div>

<button id="next4" class="btn" disabled onclick="nextPage(5)">
Reveal Surprise
</button>

</div>

<!-- PAGE 5 -->

<div id="page5" class="page">

<div class="fireworks">🎆🎉✨</div>

<h1>EID MUBARAK ❤️</h1>

<p>
Allah aapko hamesha khush rakhe ✨  
Baqra Eid Mubarak ho aapko aur aapki family ko ❤️
</p>

<button class="btn" style="background:#25D366;" onclick="openChat()">
Khair Mubarak 💬
</button>

</div>

</div>

<script>

function updateTimer(){

const now = new Date();
const target = new Date();

target.setHours(24,0,0,0);

const diff = target - now;

if(diff <= 0){

document.getElementById("timer").innerHTML = "Time Completed!";
document.getElementById("next1").disabled = false;
return;

}

const h = Math.floor(diff/3600000);
const m = Math.floor((diff%3600000)/60000);
const s = Math.floor((diff%60000)/1000);

document.getElementById("timer").innerHTML =
${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')};

}

setInterval(updateTimer,1000);

function nextPage(num){

document.querySelectorAll('.page').forEach(page=>{
page.classList.remove('active');
});

document.getElementById('page'+num).classList.add('active');

const progress = (num-1)*25;

document.getElementById('progressBar').style.width = progress+'%';

}

function checkAnswer(btn,correct){

const parent = btn.parentElement;
const buttons = parent.querySelectorAll('button');

buttons.forEach(b=>{
b.disabled = true;
});

if(correct){

btn.style.background = "#00c853";

const nextBtn =
document.getElementById(
'next'+btn.closest('.page').id.replace('page','')
);

nextBtn.disabled = false;

}else{

btn.style.background = "#ff1744";

setTimeout(()=>{
alert("Oops 😅 Wrong Answer!");
location.reload();
},500);

}

}

function openChat(){

const phone = "923107244699";

const msg = encodeURIComponent(
"Khair Mubarak ❤️ Eid Mubarak ho!"
);

window.open(
`https://wa.me/${phone}?text=${msg}`,
'_blank'
);

}

</script>

</body>
</html
